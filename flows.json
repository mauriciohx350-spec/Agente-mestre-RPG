        "name": "Montar Prompt Introdução",
        "func": "const sistema = msg.payload.sistema;\nconst tom = msg.payload.tom;\nconst local = msg.payload.local;\n\nconst prompt = `\nVocê é um mestre de RPG profissional.\n\nCrie uma introdução curta para uma aventura.\n\nSistema: ${sistema}\nTom: ${tom}\nLocal: ${local}\n\nRegras:\n\n- Máximo de 120 palavras.\n- Seja imersivo.\n- Descreva o ambiente.\n- Termine perguntando o que o jogador faz.\n- Não use listas.\n\nResponda apenas com a narrativa.\n`;\n\nconst API_KEY = \"SUA_CHAVE_API_AQUI\";\n\nmsg.payload = {\n    contents: [\n        {\n            parts: [\n                {\n                    text: prompt\n                }\n            ]\n        }\n    ]\n};\n\nmsg.url =\n\"https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent?key=\"\n+ API_KEY;\n\nmsg.headers = {\n    \"Content-Type\":\"application/json\"\n};\n\nreturn msg;",
