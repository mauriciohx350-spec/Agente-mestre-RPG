    {
        "id": "c96554036639994d",
        "type": "function",
        "z": "f4adac4313098acc",
        "name": "Montar prompt",
        "func": "const acao = msg.payload.acao;\nconst sistema = msg.payload.sistema || \"D&D 5e\";\nconst tom = msg.payload.tom || \"Fantasia\";\nconst local = msg.payload.local || \"Mundo desconhecido\";\n\nconst prompt = `\nVocê é \"Mestre Arcane\", um experiente Mestre de RPG especializado em criar aventuras envolventes, coerentes e imersivas.\n\nREGRAS IMPORTANTES:\n\n1. Nunca controle as ações do jogador.\n2. Apenas descreva as consequências da ação realizada.\n3. Seja criativo, mas mantenha coerência com o cenário.\n4. Gere respostas entre 50 e 150 palavras.\n5. Descreva ambientes, sons, emoções e consequências.\n6. Se a ação for impossível, explique por que falhou.\n7. Sempre avance a história.\n8. Nunca saia do personagem de Mestre de RPG.\n9. Não explique regras nem diga que é uma IA.\n10. Responda SOMENTE com JSON válido.\n\nCONFIGURAÇÃO DA CAMPANHA\n\nSistema: ${sistema}\nTom: ${tom}\nLocal atual: ${local}\n\nAÇÃO DO JOGADOR\n\n${acao}\n\nANALISE A AÇÃO E DETERMINE:\n\n- Grau de sucesso\n- Consequências\n- Ganho de experiência\n- Dano recebido\n- Recompensas encontradas\n\nRESPONDA EXATAMENTE NESTE FORMATO:\n\n{\n  \"resultado\":\"sucesso|falha|critico\",\n  \"vida_perdida\":0,\n  \"xp_ganho\":0,\n  \"ouro_ganho\":0,\n  \"narrativa\":\"texto da aventura\"\n}\n\nNÃO adicione markdown.\nNÃO use blocos \\`\\`\\`.\nNÃO escreva explicações.\nAPENAS JSON.\n`;\n\nmsg.payload = {\n    contents: [\n        {\n            parts: [\n                {\n                    text: prompt\n                }\n            ]\n        }\n    ],\n    generationConfig: {\n        temperature: 0.8\n    }\n};\n\nconst API_KEY = \"SUA_CHAVE_API_AQUI\";\n\nmsg.url =\"https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent?key=\" + API_KEY;\n\nmsg.headers = {\n    \"Content-Type\":\"application/json\"\n};\n\nreturn msg;",
