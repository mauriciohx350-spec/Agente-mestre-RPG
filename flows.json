        "name": "Interpretar Resposta IA",
        "func": "try {\n\n    const texto =\n        msg.payload.candidates[0]\n        .content.parts[0]\n        .text;\n\n    const limpo = texto\n        .replace(/```json/gi, \"\")\n        .replace(/```/g, \"\")\n        .trim();\n\n    const resposta = JSON.parse(limpo);\n\n    msg.payload = resposta;\n\n}\ncatch (erro) {\n\n    msg.payload = {\n        resultado: \"erro\",\n        narrativa: \"O Mestre Arcane não conseguiu interpretar a resposta da IA.\",\n        erro: erro.message\n    };\n\n}\n\nreturn msg;",
